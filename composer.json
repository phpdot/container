{
    "name": "phpdot/container",
    "description": "Server-agnostic service scoping for PHP-DI",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "php-di/php-di": "^7.0",
        "phpdot/attribute": "^1.0",
        "phpdot/contracts": "^1.2",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "psr/log": "^3.0",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Container\\": "src/"
        },
        "files": ["functions.php"]
    },
    "scripts": {
        "analyse": "phpstan analyse --memory-limit=256M",
        "test": "phpunit",
        "cs-fix": "php-cs-fixer fix"
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Container\\Tests\\": "tests/"
        }
    }
}
